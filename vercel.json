{
	"$schema": "https://openapi.vercel.sh/vercel.json",
	"crons": [
		{
			"path": "/api/cron/cleanup-sessions",
			"schedule": "0 3 * * *"
		},
		{
			"path": "/api/cron/sync-async-payments",
			"schedule": "0 */4 * * *"
		},
		{
			"path": "/api/cron/reconcile-refunds",
			"schedule": "0 */6 * * *"
		},
		{
			"path": "/api/cron/process-scheduled-discounts",
			"schedule": "0 */4 * * *"
		},
		{
			"path": "/api/cron/process-account-deletions",
			"schedule": "0 5 * * *"
		},
		{
			"path": "/api/cron/hard-delete-retention",
			"schedule": "0 8 1 * *"
		},
		{
			"path": "/api/cron/cleanup-pending-orders",
			"schedule": "*/15 * * * *"
		},
		{
			"path": "/api/cron/retry-webhooks",
			"schedule": "*/30 * * * *"
		},
		{
			"path": "/api/cron/retry-failed-emails",
			"schedule": "0 * * * *"
		},
		{
			"path": "/api/cron/abandoned-cart-emails",
			"schedule": "0 */2 * * *"
		},
		{
			"path": "/api/cron/auto-reopen-store",
			"schedule": "0 * * * *"
		}
	]
}
