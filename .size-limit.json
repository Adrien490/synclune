	},
	{
		"name": "Homepage",
		"path": ".next/static/chunks/app/(boutique)/(accueil)/*.js",
		"limit": "80 kB",
		"gzip": true
	},
	{
		"name": "Product page",
		"path": ".next/static/chunks/app/(boutique)/produits/**/*.js",
