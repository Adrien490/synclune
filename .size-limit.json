		"gzip": true
	},
	{
		"name": "Admin dashboard",
		"path": ".next/static/chunks/app/admin/(dashboard)/**/*.js",
		"limit": "200 kB",
		"gzip": true
	},
	{
		"name": "Admin catalogue",
		"path": ".next/static/chunks/app/admin/catalogue/**/*.js",
		"limit": "150 kB",
