{
	"name": "synclune-bijoux",
	"version": "0.1.0",
	"type": "module",
	"private": true,
	"packageManager": "pnpm@10.23.0",
	"engines": {
		"node": ">=22",
		"pnpm": ">=10"
	},
	"scripts": {
		"dev": "next dev --turbopack",
		"build": "prisma generate && next build --turbopack",
		"start": "next start",
		"lint": "eslint",
		"seed": "prisma db seed",
		"email:dev": "email dev --dir emails --port 3001",
		"db:studio": "prisma studio",
		"analyse": "next experimental-analyse",
		"test": "vitest",
		"test:coverage": "vitest run --coverage",
		"e2e": "playwright test",
		"e2e:ui": "playwright test --ui",
		"size": "size-limit",
		"size:check": "size-limit --json",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"typecheck": "tsc --noEmit",
		"prepare": "husky",
		"clean": "rm -rf .next node_modules/.cache coverage test-results playwright-report",
		"db:reset": "prisma migrate reset && pnpm seed",
		"db:migrate": "prisma migrate dev",
		"db:push": "prisma db push",
		"dev:debug": "NODE_OPTIONS='--inspect' next dev --turbopack",
		"validate": "pnpm lint && pnpm typecheck && pnpm format:check && pnpm test run"
	},
	"lint-staged": {
		"*.{ts,tsx,js,jsx,mjs}": [
			"eslint --fix",
			"prettier --write"
		],
		"*.{json,css,md,mdx,yml,yaml}": [
			"prettier --write"
		]
	},
