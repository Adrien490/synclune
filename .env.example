# ==============================================
# Synclune — Variables d'environnement
# ==============================================
# Copier ce fichier vers .env.local et remplir les valeurs :
#   cp .env.example .env.local
#
# Les variables marquees (requis) feront echouer le demarrage si absentes.
# Les variables marquees (optionnel) ont des valeurs par defaut ou sont ignorees en dev.

# ========================================
# Base de donnees (requis)
# ========================================
DATABASE_URL="postgresql://user:password@localhost:5432/synclune"

# ========================================
# Authentification — Better Auth (requis)
# ========================================
BETTER_AUTH_SECRET="generate-a-random-string-of-at-least-32-characters"
BETTER_AUTH_URL="http://localhost:3000"

# Google OAuth (optionnel)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ========================================
# Email — Resend (requis)
# ========================================
RESEND_API_KEY="re_your_api_key_here"
RESEND_CONTACT_EMAIL="contact@synclune.fr"

# ========================================
# Paiements — Stripe (requis)
# ========================================
STRIPE_SECRET_KEY="sk_test_your_key_here"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret_here"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_your_key_here"

# Shipping Rates Stripe (requis — IDs de vos ShippingRate Stripe)
STRIPE_SHIPPING_RATE_FRANCE="shr_your_france_rate_id"
STRIPE_SHIPPING_RATE_CORSE="shr_your_corse_rate_id"
STRIPE_SHIPPING_RATE_EUROPE="shr_your_europe_rate_id"

# ========================================
# Upload — UploadThing (requis)
# ========================================
UPLOADTHING_TOKEN="your_uploadthing_token"

# ========================================
# Rate Limiting — Arcjet (optionnel en dev, requis en prod)
# ========================================
ARCJET_KEY=""

# Listes blanches/noires IP pour le rate limiting (optionnel, comma-separated)
# RATE_LIMIT_WHITELIST=""
# RATE_LIMIT_BLACKLIST=""

# ========================================
# Cron Jobs (requis)
# ========================================
CRON_SECRET="generate-a-random-string-of-at-least-32-characters"

# ========================================
# SEO & Verification (optionnel)
# ========================================
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
# GOOGLE_SITE_VERIFICATION=""
# BING_SITE_VERIFICATION=""

# ========================================
# Vendeur / Facturation Stripe (optionnel — valeurs par defaut dans le code)
# ========================================
# VENDOR_LEGAL_NAME="Synclune"
# VENDOR_TRADE_NAME="Synclune"
# VENDOR_SIRET=""
# VENDOR_SIREN=""
# VENDOR_VAT_NUMBER=""
# VENDOR_APE_CODE=""
# VENDOR_FULL_ADDRESS=""
# VENDOR_EMAIL=""
# VENDOR_INSURANCE_COMPANY=""
# VENDOR_INSURANCE_CONTACT=""
# VENDOR_INSURANCE_COVERAGE=""
# VENDOR_VAT_EXEMPTION_TEXT=""
# VENDOR_LATE_PAYMENT_PENALTY_RATE=""
# VENDOR_RECOVERY_FEE=""
# VENDOR_REGISTRY=""
# VENDOR_OPERATION_NATURE=""

# ========================================
# Next.js (optionnel)
# ========================================
# NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=""

# ========================================
# E2E Tests (optionnel — uniquement pour Playwright)
# ========================================
# E2E_ADMIN_EMAIL="admin@synclune.fr"
# E2E_ADMIN_PASSWORD="password123"
# E2E_USER_EMAIL="test@example.com"
# E2E_USER_PASSWORD="password123"

# ========================================
# Seed (optionnel — configuration du script de seed)
# ========================================
# SEED_CLEANUP="false"
# SEED_ADMIN_EMAIL="admin@synclune.fr"
# SEED_ORDER_COUNT="50"
# SEED_USER_COUNT="10"
# SEED_ORDER_PREFIX="SYN"
